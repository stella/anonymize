{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "rules": {
    "files": "off",
    "dependencies": "error",
    "devDependencies": "off",
    "optionalPeerDependencies": "off",
    "binaries": "off",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "duplicates": "off",
    "unlisted": "error",
    "unresolved": "error"
  },
  "ignoreDependencies": ["@napi-rs/wasm-runtime"]
}
