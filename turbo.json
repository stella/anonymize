{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [".oxfmtrc.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "wasm/dist/**",
        "native-wasm-dist/**",
        "stella_anonymize_napi.node",
        "native-pipeline.stlanonpkg",
        "native-pipeline.*.stlanonpkg"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {},
    "format": {},
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
