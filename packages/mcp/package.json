{
  "name": "@stll/anonymize-mcp",
  "version": "2.3.0",
  "description": "Path-only local MCP server for stella PII anonymization",
  "type": "module",
  "bin": {
    "stella-anonymize-mcp": "./dist/server-entry.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "homepage": "https://github.com/stella/anonymize",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "bun ../../scripts/tsc-native.ts --noEmit -p tsconfig.json && bun ../../scripts/tsc-native.ts --noEmit -p tsconfig.test.json",
    "test": "bun test src/__test__/local.test.ts src/__test__/server.test.ts && bun run test:node-runtime",
    "test:node-runtime": "node --import tsx --test src/__test__/durable-sessions.test.ts && node scripts/test-packed-bin.mjs",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stll/anonymize": "workspace:*",
    "@stll/anonymize-docx": "^2.3.0",
    "@stll/anonymize-pdf": "workspace:*",
    "fs-native-extensions": "^1.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "expect": "^30.2.0",
    "fflate": "^0.8.3",
    "tsdown": "^0.22.7",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
