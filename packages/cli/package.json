{
  "name": "@stll/anonymize-cli",
  "version": "2.0.2",
  "description": "Command-line PII detection and anonymization powered by @stll/anonymize",
  "keywords": [
    "anonymization",
    "pii",
    "redaction",
    "ner",
    "pseudonymization",
    "gdpr",
    "privacy",
    "cli"
  ],
  "type": "module",
  "bin": {
    "anonymize": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "homepage": "https://github.com/stella/anonymize",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "bun test --timeout 60000",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@stll/anonymize": "^2.0.2",
    "@stll/anonymize-data": "^0.0.6",
    "@stll/anonymize-docx": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "fflate": "^0.8.3",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3"
  }
}
