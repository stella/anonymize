{
  "name": "@stll/anonymize-data",
  "version": "0.0.6",
  "description": "Deny list dictionaries and config data for @stll/anonymize",
  "keywords": [
    "anonymization",
    "pii",
    "redaction",
    "ner",
    "pseudonymization",
    "gdpr",
    "privacy",
    "dictionaries"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./dictionaries": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./config/*": "./config/*",
    "./dictionaries/*": "./dictionaries/*"
  },
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "ATTRIBUTION.md",
    "CHANGELOG.md",
    "config",
    "dictionaries/banks",
    "dictionaries/cities",
    "dictionaries/courts",
    "dictionaries/education",
    "dictionaries/government",
    "dictionaries/healthcare",
    "dictionaries/insurance",
    "dictionaries/international",
    "dictionaries/names"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "homepage": "https://github.com/stella/anonymize",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "validate:triggers": "bun run scripts/validate-triggers.ts",
    "check:mirror": "node scripts/check-mirror.mjs",
    "lint": "bun run validate:triggers && bun run check:mirror",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "stopwords-iso": "1.1.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
