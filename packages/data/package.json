{
  "name": "@stll/anonymize-data",
  "version": "0.1.0",
  "description": "Deny list dictionaries and config data for @stll/anonymize",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dictionaries": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config/*": "./config/*",
    "./dictionaries/*": "./dictionaries/*"
  },
  "types": "dist/index.d.ts",
  "files": ["dist", "config", "dictionaries"],
  "publishConfig": {
    "access": "restricted"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "stopwords-iso": "1.1.0",
    "tsdown": "^0.12.4",
    "typescript": "^5.9.3"
  }
}
