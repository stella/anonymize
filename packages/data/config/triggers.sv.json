    "validations": [{ "type": "has-digits" }]
  },
  {
    "id": "sv-clinical-patient-number",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["patientnummer", "patient-ID", "patientidentifikator"],
