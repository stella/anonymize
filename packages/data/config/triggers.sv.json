    "triggers": ["folkbokförd i", "folkbokförd på", "bosatt i", "bosatt på"]
  },
  {
    "id": "sv-date-of-birth",
    "label": "date of birth",
    "strategy": {
      "type": "n-words",
      "count": 4
    },
    "triggers": ["född den"]
  },
  {
    "id": "sv-person",
    "label": "person",
    "strategy": { "type": "to-next-comma" },
    "triggers": ["kontaktperson"],
    "validations": [{ "type": "starts-uppercase" }]
  },
  {
    "id": "sv-bank-account",
    "label": "bank account number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["bankgiro", "plusgiro"]
  },
  {
    "id": "sv-tax-id",
    "label": "tax identification number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["momsregistreringsnummer"]
  },
  {
