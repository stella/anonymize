    "validations": [{ "type": "has-digits" }]
  },
  {
    "id": "sv-clinical-health-card-number",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": [
      "sjukförsäkringskortets nummer",
      "försäkringskortsnummer",
      "EU-kortets nummer"
