[
  {
    "id": "en-person",
    "label": "person",
    "strategy": { "type": "to-next-comma" },
    "triggers": ["represented by"],
    "validations": [{ "type": "starts-uppercase" }]
  },
  {
    "id": "en-date-of-birth",
    "label": "date of birth",
    "strategy": {
      "type": "n-words",
      "count": 4
    },
    "triggers": ["born on"]
  },
  {
    "id": "en-address",
    "label": "address",
    "strategy": { "type": "to-next-comma" },
    "triggers": [
      "born in",
      "residing at",
      "residing in",
      "resident of",
      "national of",
      "living in",
      "domiciled in"
    ]
  },
  {
    "id": "en-jurisdiction",
    "label": "address",
    "strategy": {
      "type": "to-next-comma",
      "maxLength": 30,
      "stopWords": [
        "or",
        "and",
        "in",
        "sitting",
        "shall",
        "that",
        "which",
        "without",
        "for",
        "to"
      ]
    },
    "triggers": ["State of", "Commonwealth of", "District of", "Territory of"],
    "includeTrigger": true,
    "extensions": ["normalize-spaces"],
    "validations": [{ "type": "starts-uppercase" }]
  },
  {
    "id": "en-company-id",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": [
      "registration number",
      "company id",
      "company number",
      "KvK",
      "Kamer van Koophandel"
    ]
  },
  {
    "id": "en-tax-id",
    "label": "tax identification number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["VAT number", "VAT ID", "tax identification number", "tax id"]
  },
  {
    "id": "en-us-social-security-number",
    "label": "social security number",
    "strategy": {
      "type": "match-pattern",
      "pattern": "^(?:(?!000|666|9[0-9]{2})[0-9]{3}[-‐‑‒–—―](?!00)[0-9]{2}[-‐‑‒–—―](?!0000)[0-9]{4}|(?!000|666|9[0-9]{2})[0-9]{3} (?!00)[0-9]{2} (?!0000)[0-9]{4}|(?!000|666|9[0-9]{2})[0-9]{3}(?!00)[0-9]{2}(?!0000)[0-9]{4})\\b(?![-‐‑‒–—―+/.][\\p{L}\\p{N}])"
    },
    "triggers": [
      "Social Security Number",
      "Social Security No",
      "Social Security No.",
      "SSN"
    ],
    "extensions": ["add-colon", "add-colon-space"]
  },
  {
    "id": "en-uk-companies-house",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": [
      "Companies House",
      "Company No.",
      "Company No",
      "registered number",
      "CRN"
    ],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [
      {
        "type": "matches-pattern",
        "pattern": "^(?:SC|NI|OC|SO|R|FC|GE|GS|IC|IP|LP|NC|NF|NL|NO|NP|NR|NZ|RC|SA|SF|SI|SL|SP|SR|SZ)?\\d{6,8}$"
      }
    ]
  },
  {
    "id": "en-uk-utr",
    "label": "tax identification number",
    "strategy": { "type": "company-id-value" },
    "triggers": [
      "UTR",
      "Unique Tax Reference",
      "Unique Taxpayer Reference",
      "Self Assessment UTR"
    ],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [{ "type": "matches-pattern", "pattern": "^\\d{10}$" }]
  },
  {
    "id": "en-clinical-medical-record-number",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["medical record number", "clinical record number", "MRN"],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [{ "type": "has-digits" }]
  },
  {
    "id": "en-clinical-patient-number",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["patient number", "patient ID", "patient identifier"],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [{ "type": "has-digits" }]
  },
  {
    "id": "en-clinical-health-card-number",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": [
      "health card number",
      "health insurance card number",
      "insurance card number"
    ],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [{ "type": "has-digits" }]
  }
]
