[
  {
    "id": "en-person",
    "label": "person",
    "strategy": { "type": "to-next-comma" },
    "triggers": ["represented by"],
    "validations": [{ "type": "starts-uppercase" }]
  },
  {
    "id": "en-date-of-birth",
    "label": "date of birth",
    "strategy": {
      "type": "n-words",
      "count": 4
    },
    "triggers": ["born on"]
  },
  {
    "id": "en-address",
    "label": "address",
    "strategy": { "type": "to-next-comma" },
    "triggers": [
      "born in",
      "residing at",
      "residing in",
      "resident of",
      "national of",
      "living in",
      "domiciled in"
    ]
  },
  {
    "id": "en-jurisdiction",
    "label": "address",
    "strategy": {
      "type": "to-next-comma",
      "maxLength": 30,
      "stopWords": [
        "or",
        "and",
        "in",
        "sitting",
        "shall",
        "that",
        "which",
        "without",
        "for",
        "to"
      ]
    },
    "triggers": ["State of", "Commonwealth of", "District of", "Territory of"],
    "includeTrigger": true,
    "extensions": ["normalize-spaces"],
    "validations": [{ "type": "starts-uppercase" }]
  },
  {
    "id": "en-company-id",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["registration number", "company id", "company number"]
  },
  {
    "id": "en-tax-id",
    "label": "tax identification number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["VAT number", "VAT ID", "tax identification number", "tax id"]
  },
  {
    "id": "en-uk-companies-house",
    "label": "registration number",
    "strategy": { "type": "company-id-value" },
    "triggers": ["Companies House", "Company No.", "Company No", "CRN"],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [
      {
        "type": "matches-pattern",
        "pattern": "^(?:SC|NI|OC|SO|R|FC|GE|GS|IC|IP|LP|NC|NF|NL|NO|NP|NR|NZ|RC|SA|SF|SI|SL|SP|SR|SZ)?\\d{6,8}$"
      }
    ]
  },
  {
    "id": "en-uk-utr",
    "label": "tax identification number",
    "strategy": { "type": "company-id-value" },
    "triggers": [
      "UTR",
      "Unique Tax Reference",
      "Unique Taxpayer Reference",
      "Self Assessment UTR"
    ],
    "extensions": ["add-colon", "add-colon-space"],
    "validations": [{ "type": "matches-pattern", "pattern": "^\\d{10}$" }]
  }
]
