{
  "name": "@stll/anonymize-benchmark",
  "version": "0.0.0",
  "description": "Reproducible comparison of stella/anonymize against open-source PII redaction libraries across public development and sealed evaluation corpora",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "bun ../../scripts/tsc-native.ts --noEmit -p tsconfig.json",
    "test": "bun test",
    "format": "oxfmt . \"!results/**\" \"!vendor/**\"",
    "bench:compare": "bun src/bench.ts",
    "bench:blind": "bun src/blind.ts",
    "bench:dev-gap": "bun src/dev-gap.ts",
    "bench:redactionbench": "bun src/redactionbench.ts",
    "bench:meddocan": "bun src/meddocan.ts",
    "bench:suite": "bun src/suite.ts"
  },
  "dependencies": {
    "@stll/anonymize": "workspace:^",
    "@stll/anonymize-data": "^0.0.6",
    "fflate": "0.8.2",
    "hyparquet": "1.26.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
