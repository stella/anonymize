{
  "name": "@stll/anonymize-benchmark",
  "version": "0.0.0",
  "description": "Reproducible comparison of stella/anonymize against open-source PII redaction libraries on recall, precision, and throughput over a public synthetic legal corpus",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "format": "oxfmt . \"!results/**\" \"!vendor/**\"",
    "bench:compare": "bun src/bench.ts"
  },
  "dependencies": {
    "@stll/anonymize": "workspace:^",
    "@stll/anonymize-data": "^0.0.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
