{
  "name": "@stll/anonymize-docx",
  "version": "2.2.0",
  "description": "Structure-aware DOCX text extraction and rewriting for stella anonymization workflows",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "ATTRIBUTION.md",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsdown",
    "typecheck": "bun ../../scripts/tsc-native.ts --noEmit -p tsconfig.json && bun ../../scripts/tsc-native.ts --noEmit -p tsconfig.test.json",
    "test": "bun test",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@stll/anonymize": "^2.2.0",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "tsdown": "^0.22.7",
    "typescript": "^6.0.3"
  }
}
