[
  {
    "id": "swift-bic",
    "triggers": ["SWIFT", "BIC"],
    "label": "bank account number",
    "strategy": {
      "type": "n-words",
      "count": 1
    },
    "extensions": ["add-colon"],
    "validations": [
      {
        "type": "matches-pattern",
        "pattern": "^[A-Za-z]{4}[A-Za-z]{2}[A-Za-z0-9]{2}(?:[A-Za-z0-9]{3})?$"
      }
    ]
  },
  {
    "id": "us-aba-routing",
    "triggers": [
      "ABA",
      "ABA Number",
      "RTN",
      "Routing Number",
      "Routing No.",
      "Routing Transit Number"
    ],
    "label": "bank account number",
    "strategy": {
      "type": "n-words",
      "count": 1
    },
    "extensions": ["add-colon"],
    "validations": [
      {
        "type": "has-digits"
      },
      {
        "type": "valid-id",
        "validator": "us.rtn"
      }
    ]
  },
  {
    "id": "amount-prefix",
    "triggers": [
      "ve výši",
      "in the amount of",
      "in Höhe von",
      "d'un montant de",
      "w wysokości",
      "nell'importo di",
      "por un importe de"
    ],
    "label": "monetary amount",
    "strategy": {
      "type": "to-next-comma"
    },
    "extensions": ["add-colon"],
    "validations": [
      {
        "type": "has-digits"
      }
    ]
  }
]
