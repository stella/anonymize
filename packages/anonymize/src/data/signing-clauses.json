{
  "_comment": "Signing clause patterns. Captures the place name from contract signing locations. Each entry: prefix/suffix build regexes; prefilterPhrases gate native regex scans; guardPrefixPhrases/guardSuffixPhrases suppress deny-list place hits in the same signing context.",
  "patterns": [
    {
      "lang": "cs",
      "prefix": "(?:V|Ve)\\s+",
      "suffix": "\\s*,?\\s*dne",
      "prepositions": ["nad", "pod", "u", "ve", "na"],
      "prefilterPhrases": ["dne"],
      "guardPrefixPhrases": ["v", "ve"],
      "guardSuffixPhrases": ["dne"]
    },
    {
      "lang": "sk",
      "prefix": "(?:V|Vo)\\s+",
      "suffix": "\\s*,?\\s*dňa",
      "prepositions": ["nad", "pod", "pri"],
      "prefilterPhrases": ["dňa"],
      "guardPrefixPhrases": ["v", "vo"],
      "guardSuffixPhrases": ["dňa"]
    },
    {
      "lang": "de",
      "prefix": "",
      "suffix": "\\s*,\\s*den",
      "prepositions": ["am", "an", "im"],
      "prefilterPhrases": ["den"],
      "guardPrefixPhrases": [""],
      "guardSuffixPhrases": ["den"]
    },
    {
      "lang": "fr",
      "prefix": "(?:Fait\\s+)?[Àà]\\s+",
      "suffix": "\\s*,?\\s*le",
      "prepositions": [],
      "prefilterPhrases": ["À ", "à "],
      "guardPrefixPhrases": ["à", "fait à"],
      "guardSuffixPhrases": ["le"]
    },
    {
      "lang": "en",
      "prefix": "(?:Signed|Executed)\\s+in\\s+",
      "suffix": "",
      "prepositions": [],
      "prefilterPhrases": ["Signed in", "Executed in"],
      "guardPrefixPhrases": ["signed in", "executed in"],
      "guardSuffixPhrases": [""]
    },
    {
      "lang": "pl",
      "prefix": "(?:W|We)\\s+",
      "suffix": "\\s*,?\\s*dnia",
      "prepositions": ["nad", "pod", "przy"],
      "prefilterPhrases": ["dnia"],
      "guardPrefixPhrases": ["w", "we"],
      "guardSuffixPhrases": ["dnia"]
    },
    {
      "lang": "it",
      "prefix": "(?:Fatto\\s+)?[Aa]\\s+",
      "suffix": "\\s*,?\\s*(?:il|lì)",
      "prepositions": [],
      "prefilterPhrases": ["A ", "a "],
      "guardPrefixPhrases": ["a", "fatto a"],
      "guardSuffixPhrases": ["il", "lì"]
    },
    {
      "lang": "es",
      "prefix": "(?:Firmado\\s+)?[Ee]n\\s+",
      "suffix": "\\s*,?\\s*(?:a|el)",
      "prepositions": ["de", "del"],
      "prefilterPhrases": ["En ", "en "],
      "guardPrefixPhrases": ["en", "firmado en"],
      "guardSuffixPhrases": ["a", "el"]
    }
  ]
}
