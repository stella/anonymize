  {
    "id": "pl-person-honorific",
    "label": "person",
    "strategy": { "type": "n-words", "count": 2 },
    "triggers": [
      "Pana",
      "Panią",
      "dr hab.",
      "prof.",
      "prof. dr hab.",
      "mgr",
      "mgr inż.",
      "mgr inż",
      "inż.",
      "inż"
    ],
    "extensions": ["add-trailing-space"],
    "validations": [
      { "type": "starts-uppercase" },
      {
        "type": "matches-pattern",
        "pattern": "^\\p{Lu}[\\p{L}'\\-]*(?:\\s+\\p{Lu}[\\p{L}'\\-]*)?[.,;:!?]?$",
        "flags": "u"
      }
    ]
  },
