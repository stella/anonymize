    ],
    "extensions": ["add-colon"],
    "validations": [
      { "type": "has-digits" },
      {
        "type": "matches-pattern",
        "pattern": "(?:PLN|zł|EUR|USD|CZK|CHF|GBP|\\$|€|£)",
        "flags": "i"
