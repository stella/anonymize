{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@stll/typescript-config/library.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "noEmit": true,
    "target": "ES2023"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "src/**/__test__/**",
    "src/**/*.test.ts",
    "src/wasm.ts"
  ]
}
