{
  "name": "@stll/anonymize-wasm",
  "version": "0.1.0",
  "description": "PII detection and anonymization for browsers via WebAssembly. Same API as @stll/anonymize.",
  "type": "module",
  "module": "dist/wasm.mjs",
  "types": "dist/wasm.d.mts",
  "exports": {
    ".": {
      "types": "./dist/wasm.d.mts",
      "import": "./dist/wasm.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "license": "MIT",
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.2",
    "@stll/stdnum": "^0.0.1",
    "@stll/text-search-wasm": "^0.1.0"
  },
  "peerDependencies": {
    "@stll/anonymize-data": "^0.0.3"
  },
  "peerDependenciesMeta": {
    "@stll/anonymize-data": {
      "optional": true
    }
  }
}
