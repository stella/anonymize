{
  "name": "@stll/anonymize-wasm",
  "version": "2.0.1",
  "description": "PII detection and anonymization for browsers via WebAssembly. Same native SDK API as @stll/anonymize.",
  "keywords": [
    "anonymization",
    "pii",
    "redaction",
    "ner",
    "pseudonymization",
    "gdpr",
    "privacy",
    "wasm",
    "browser"
  ],
  "type": "module",
  "module": "dist/wasm.mjs",
  "types": "dist/wasm.d.mts",
  "exports": {
    ".": {
      "types": "./dist/wasm.d.mts",
      "import": "./dist/wasm.mjs"
    },
    "./constants": {
      "types": "./dist/constants.d.mts",
      "import": "./dist/constants.mjs",
      "default": "./dist/constants.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "homepage": "https://github.com/stella/anonymize",
  "license": "Apache-2.0",
  "dependencies": {
    "@napi-rs/wasm-runtime": "^1.1.6"
  },
  "peerDependencies": {
    "vite": ">=5 <10"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
