{
  "name": "@stll/anonymize-wasm",
  "version": "1.0.8",
  "description": "PII detection and anonymization for browsers via WebAssembly. Same API as @stll/anonymize.",
  "type": "module",
  "module": "dist/wasm.mjs",
  "types": "dist/wasm.d.mts",
  "exports": {
    ".": {
      "types": "./dist/wasm.d.mts",
      "import": "./dist/wasm.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "license": "MIT",
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.2",
    "@stll/stdnum": "^0.0.1",
    "@stll/text-search-wasm": "^1.0.1"
  },
  "peerDependencies": {
    "@stll/anonymize-data": "^0.0.4",
    "vite": ">=5 <10"
  },
  "peerDependenciesMeta": {
    "@stll/anonymize-data": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
