{
  "name": "@stll/anonymize",
  "version": "2.0.1",
  "description": "Deterministic PII detection and anonymization with regex, deny lists, and coreference resolution",
  "keywords": [
    "anonymization",
    "pii",
    "redaction",
    "pseudonymization",
    "gdpr",
    "privacy"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./constants": {
      "types": "./dist/constants.d.mts",
      "import": "./dist/constants.mjs",
      "default": "./dist/constants.mjs"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.mts",
      "import": "./dist/capabilities.mjs",
      "default": "./dist/capabilities.mjs"
    },
    "./native": {
      "types": "./dist/native.d.mts",
      "import": "./dist/native.mjs",
      "default": "./dist/native.mjs"
    },
    "./native-node": {
      "types": "./dist/native-node.d.mts",
      "import": "./dist/native-node.mjs",
      "default": "./dist/native-node.mjs"
    }
  },
  "types": "dist/index.d.mts",
  "bin": {
    "stella-anonymize-build-native-package": "./scripts/build-native-pipeline-package.mjs"
  },
  "files": [
    "ATTRIBUTION.md",
    "dist",
    "index.cjs",
    "native-pipeline.stlanonpkg",
    "native-pipeline.*.stlanonpkg",
    "scripts/build-native-pipeline-package.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "homepage": "https://github.com/stella/anonymize",
  "license": "Apache-2.0",
  "scripts": {
    "build": "bun run build:native-wasm && tsdown && bun scripts/build-native-node.mjs && bun run build:wasm-assets",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.wasm.json",
    "test": "bun test --timeout 15000",
    "test:fast": "bun run test src/__test__/*.test.ts",
    "test:native-fixtures": "ANONYMIZE_TEST_SLOW_NATIVE_FIXTURE_PARITY=1 bun test --timeout 600000 src/__test__/python-parity.test.ts",
    "perf:native-adapters": "bun scripts/native-adapter-perf.mjs",
    "perf:native-default": "bun scripts/native-default-sdk-perf.mjs",
    "perf:native-default:summary": "ANONYMIZE_NATIVE_DEFAULT_SDK_PERF_OUTPUT=summary bun scripts/native-default-sdk-perf.mjs",
    "check:v1-native": "bun scripts/native-v1-readiness.mjs",
    "check:v1-native:full": "ANONYMIZE_V1_READINESS_MODE=full bun scripts/native-v1-readiness.mjs",
    "smoke:dist": "bun scripts/dist-smoke.mjs",
    "build:native-wasm": "node scripts/build-native-wasm.mjs",
    "build:wasm-assets": "node scripts/build-native-wasm-assets.mjs",
    "smoke:wasm": "node scripts/smoke-wasm.mjs",
    "smoke:wasm-package": "node scripts/smoke-wasm-package.mjs",
    "smoke:wasm-browser": "node scripts/smoke-wasm-browser.mjs",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "@stll/stdnum": "^2.1.1",
    "@stll/text-search": "^1.0.7"
  },
  "peerDependencies": {
    "@stll/anonymize-data": "^0.0.6"
  },
  "peerDependenciesMeta": {
    "@stll/anonymize-data": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@stll/anonymize-darwin-arm64": "2.0.1",
    "@stll/anonymize-darwin-x64": "2.0.1",
    "@stll/anonymize-linux-arm64-gnu": "2.0.1",
    "@stll/anonymize-linux-x64-gnu": "2.0.1",
    "@stll/anonymize-win32-x64-msvc": "2.0.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@stll/anonymize-data": "workspace:*",
    "@stll/text-search-wasm": "^1.0.7",
    "bun-types": "^1.3.14",
    "fast-check": "^4.8.0",
    "puppeteer-core": "25.3.0",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
