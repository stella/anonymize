{
  "name": "@stll/anonymize",
  "version": "1.0.2",
  "description": "Multi-layer PII detection and anonymization pipeline with regex, NER, deny lists, and coreference resolution",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.wasm.json",
    "test": "bun test",
    "lint": "prettier --check . --ignore-path ../../.prettierignore",
    "format": "prettier --write . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.2",
    "@stll/stdnum": "^0.0.1",
    "@stll/text-search": "^0.1.2"
  },
  "peerDependencies": {
    "@stll/anonymize-data": "^0.0.4"
  },
  "peerDependenciesMeta": {
    "@stll/anonymize-data": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stll/text-search-wasm": "^0.1.2",
    "bun-types": "^1.3.11",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
