{
  "name": "@stll/anonymize",
  "version": "0.3.3",
  "description": "Multi-layer PII detection and anonymization pipeline with regex, NER, deny lists, and coreference resolution",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stella/anonymize.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured yet'",
    "format": "echo 'no formatter configured yet'"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.2",
    "@stll/stdnum": "^0.5.0",
    "@stll/text-search": "^0.3.3"
  },
  "peerDependencies": {
    "@stll/anonymize-data": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@stll/anonymize-data": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsdown": "^0.12.4",
    "typescript": "^5.9.3"
  }
}
